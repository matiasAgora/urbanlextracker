# ==========================================
# Urban Lex Tracker - Environment Variables
# ==========================================

# Secret key for JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production

# Gemini API Key for summarizing reports
GEMINI_API_KEY=your_gemini_api_key_here

# Database path (optional, defaults to sqlite:///./urbanlextracker.db)
# DB_URL=sqlite:///./urbanlextracker.db
